SERVER_PORT=8080
DB_URL=jdbc:mysql://localhost:3306/worshipflow?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=worshipflow
DB_USERNAME=root
DB_PASSWORD=
JPA_DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FRONTEND_BASE_URL=http://localhost:8080
EXPOSE_RESET_LINK=false

# Valores aceitos: auto, supabase, smtp
PASSWORD_RESET_PROVIDER=supabase

# Supabase Auth usa o SMTP configurado no painel do projeto para enviar o e-mail.
# SUPABASE_SERVICE_ROLE_KEY e opcional, mas permite espelhar o usuario local no Supabase Auth antes do envio.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP direto opcional. Use apenas se o backend for enviar direto por um provedor SMTP.
MAIL_HOST=
MAIL_PORT=587
MAIL_FROM=noreply@worshipflow.local
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=true
